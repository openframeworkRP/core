# This file describes files and paths that should not be tracked by Git version control
# https://git-scm.com/docs/gitignore

# Auto-generated code editor files
.vs/*
.vscode/*
*.csproj
obj
bin
Properties/*
code/obj/*
code/Properties/*

# Auto-generated asset related files
.sbox/
*.generated.*
*_c
*.los
*.vpk
*launchSettings.json
*.sln
*.slnx
*idea

# Fichiers compiles s&box (regeneres au build, ne pas tracker)
*.vtex_c
*.vmdl_c
*.vsnd_c
*.vmat_c
*.vpcf_c
*.vanim_c
*.vagrp_c
*.vrman_c
*.vsmart_c
*.scene_c
*.scene_d
*.shader_c

# Exported / standalone games
Exports/

# Fichiers de sauvegarde automatiques
*.blend1
*.blend2
*.blend3
*.blend4
*.blend5

# Fichiers temporaires / lock
*.blend@
*.blend.lock
*.blend.tmp
