				{
					_class = "CCommentAnimNode"
					m_sName = "Reset forwarders"
					m_vecPosition = [ -704.0, -640.0 ]
					m_nNodeID = 
					{
						m_id = 1920770299
					}
					m_sNote = ""
					m_commentText = "You may have seen \'RESET BLOCKERS\' all over the place... and now, ironically, I find myself using Bone Mask nodes for the exact opposite purpose. You see, the resets coming from the \'Reset phase if idle\' group would not get forwarded to the animations outside this subgraph because the 1D Blendspaces aren\'t forwarding resets to inactive animations... the movement additives are on move_bob = 1, but the resets effectively happen when we\'ve effectively been at 0 for 300ms... the best and least hacky solution I could find was to do this."
					m_size = [ 544.0, 256.0 ]
					m_color = [ 255, 0, 0, 255 ]
				}
