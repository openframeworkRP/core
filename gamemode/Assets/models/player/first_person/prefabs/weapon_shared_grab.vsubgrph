			},
			{
				key = 
				{
					m_id = 1556947468
				}
				value = 
				{
					_class = "CCommentAnimNode"
					m_sName = "What the hell is going on here"
					m_vecPosition = [ -384.0, -224.0 ]
					m_nNodeID = 
					{
						m_id = 1556947468
					}
					m_sNote = ""
					m_commentText = "By having all compositing steps be as part of the inputs of the state machine, you can consider all of this to be \'part of the animation sequences\' — like an AnimMontage in Unreal.\n\nThe core idea behind this:\n\nWhen the grab stance turns on, we switch from parent-space to model-space compositing, and when it turns off, we do the opposite.\n\nThis way, when in grab stance, the hand is always in the same spot regardless of what\'s happening with the right arm (and weapon)."
					m_size = [ 512.0, 304.0 ]
					m_color = [ 0, 165, 255, 255 ]
				}
			},
