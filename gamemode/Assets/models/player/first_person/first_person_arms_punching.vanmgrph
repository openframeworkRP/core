									m_vecPosition = [ -80.0, -528.0 ]
									m_nNodeID = 
									{
										m_id = 1431861822
									}
									m_sNote = ""
									m_commentText = "Each Hit/Miss node has 2 versions so that attacks can repeat seamlessly into themselves without the \"hard cut\" that an \"Always Evaluate\" node would bring. That method is usually good for firing guns but I wanted at least a small blend time here.\n\nHOWEVER, it turns out that this isn\'t accomplishing its end goal anyway, because the Choice nodes do the reset in such a way that induces the hard transition. This may be solved in the future..."
