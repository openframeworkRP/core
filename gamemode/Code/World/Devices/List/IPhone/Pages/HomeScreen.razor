@using Sandbox;
@using Sandbox.UI;
@using OpenFramework.World.Devices
@using OpenFramework.World.Devices.Shared

@implements IDevice.IScreenContext
@inherits Panel
@namespace OpenFramework.World.Devices.Phone

@if (Client.Local == null) return;

<root>
    <AppLauncher Device=@AttachedDevice Container=@this ShowPinned=@false />
    <AppLauncher Device=@AttachedDevice Container=@this ShowPinned=@true />
</root>

@code {
    public IDevice AttachedDevice { get; set; }

    protected override int BuildHash() => 0;
}
