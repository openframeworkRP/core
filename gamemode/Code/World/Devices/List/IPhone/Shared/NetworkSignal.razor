@namespace OpenFramework.World.Devices.Phone
@inherits Panel

<root>
    <div class="bars">
        @for (int i = 1; i <= 4; i++)
        {
            <div class="bar @(i <= SignalStrength ? "active" : "")"></div>
        }
    </div>
</root>

@code {
    public int SignalStrength { get; set; } = 3; // 0 à 4
}
