@using OpenFramework.World.Devices
@using Sandbox.UI

@namespace OpenFramework.World.Devices.Phone
@inherits Panel

@* Panel transparent full-screen, intercepte les swipes sans bloquer les clics enfants *@
<root>
    @* Zone de déclenchement HAUT → on swipe depuis le bord haut *@
    <div class="trigger-top"
         @onmousedown=@( (MousePanelEvent e) => OnTopTriggerDown(e) ) />

    @* Zone de déclenchement BAS → on swipe depuis le bord bas (home bar) *@
    <div class="trigger-bottom"
         @onmousedown=@( (MousePanelEvent e) => OnBottomTriggerDown(e) ) />
</root>

@code {

    // ── Callbacks exposés au parent ──────────────────────────────
    /// <summary>Swipe du haut vers le bas (ex: ouvrir Control Center)</summary>
    public Action OnSwipeDown { get; set; }

    /// <summary>Swipe du bas vers le haut (ex: revenir Home / fermer overlay)</summary>
    public Action OnSwipeUp { get; set; }

    // ── État interne ─────────────────────────────────────────────
    private bool _dragging = false;
    private SwipeOrigin _origin = SwipeOrigin.None;
    private float _startY = 0f;
    private float _currentOffset = 0f;

    private const float Threshold = 80f; // px à parcourir pour valider le swipe

    private enum SwipeOrigin { None, Top, Bottom }

    // ── Déclenchement depuis les zones ───────────────────────────

    private void OnTopTriggerDown( MousePanelEvent e )
    {
        BeginDrag( e.LocalPosition.y, SwipeOrigin.Top );
        e.StopPropagation();
    }

    private void OnBottomTriggerDown( MousePanelEvent e )
    {
        BeginDrag( e.LocalPosition.y, SwipeOrigin.Bottom );
        e.StopPropagation();
    }

    private void BeginDrag( float startY, SwipeOrigin origin )
    {
        _dragging = true;
        _origin = origin;
        _startY = startY;
        _currentOffset = 0f;
    }

    // ── Mouse move / up sur le panel racine ──────────────────────

    protected override void OnMouseMove( MousePanelEvent e )
    {
        if ( !_dragging ) return;

        _currentOffset = e.LocalPosition.y - _startY;

        // Swipe vers le bas depuis le haut
        if ( _origin == SwipeOrigin.Top && _currentOffset > Threshold )
        {
            Commit( SwipeOrigin.Top );
            return;
        }

        // Swipe vers le haut depuis le bas
        if ( _origin == SwipeOrigin.Bottom && _currentOffset < -Threshold )
        {
            Commit( SwipeOrigin.Bottom );
            return;
        }
    }

    protected override void OnMouseUp( MousePanelEvent e )
    {
        Reset();
    }

    // ── Commit & reset ───────────────────────────────────────────

    private void Commit( SwipeOrigin origin )
    {
        Reset();

        if ( origin == SwipeOrigin.Top )
        {
            Log.Info( "[SwipeGesture] ↓ Swipe haut → bas" );
            OnSwipeDown?.Invoke();
        }
        else
        {
            Log.Info( "[SwipeGesture] ↑ Swipe bas → haut" );
            OnSwipeUp?.Invoke();
        }
    }

    private void Reset()
    {
        _dragging = false;
        _origin = SwipeOrigin.None;
        _currentOffset = 0f;
    }
}
