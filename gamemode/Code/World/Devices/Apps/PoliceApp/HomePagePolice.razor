@using Sandbox;
@using Sandbox.UI;

@namespace OpenFramework.World.Devices.Apps.Police
@inherits Panel

<root>
    <div class="container">

        <div class="topbar">
            <svg class="topbar-icon" src="ui/icons/apps/policeicon.svg" color="#273CF5" />
            <span class="topbar-title">Bienvenu(e), @_myFirstName @_myLastName</span>
            <div class="topbar-grade">
                <span>@(_myGrade ?? "Officier")</span>
            </div>
        </div>

        <div class="row-stats">
            <div class="stat-card">
                <span class="stat-value">@_policeOnline.Count</span>
                <span class="stat-label">Unités en service</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@_wantedCount</span>
                <span class="stat-label">Personnes recherchées</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@_cuffedCount</span>
                <span class="stat-label">En garde à vue</span>
            </div>
        </div>

        <div class="units">
            <span class="section-title">Unités en service</span>
            <table>
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Grade</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach ( var unit in _policeOnline )
                    {
                        <tr class="@(unit == _myData ? "row-self" : "")">
                            <td>@unit.LastName</td>
                            <td>@unit.FirstName</td>
                            <td>@(string.IsNullOrEmpty(unit.JobGrade) ? "Officier" : unit.JobGrade)</td>
                            <td><span class="badge-online">En service</span></td>
                        </tr>
                    }
                    @if ( _policeOnline.Count == 0 )
                    {
                        <tr>
                            <td colspan="4"><span class="no-units">Aucune unité en service</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</root>

@code
{
    private ClientData _myData;
    private string     _myFirstName = "";
    private string     _myLastName  = "";
    private string     _myGrade;
    private List<ClientData> _policeOnline = new();
    private int  _wantedCount;
    private int  _cuffedCount;

    private void Refresh()
    {
        var all = Game.ActiveScene?.GetAllComponents<ClientData>() ?? Enumerable.Empty<ClientData>();

        _myData      = Client.Local?.Components.Get<ClientData>();
        _myFirstName = _myData?.FirstName ?? "";
        _myLastName  = _myData?.LastName  ?? "";
        _myGrade     = _myData?.JobGrade;

        _policeOnline = all.Where( d => d.Job?.ToLower() == "police" ).ToList();
        _wantedCount  = all.Count( d => d.WantedLevel > 0 );
        _cuffedCount  = all.Count( d => d.IsCuffed );
    }

    protected override int BuildHash()
    {
        Refresh();
        return HashCode.Combine( _policeOnline.Count, _wantedCount, _cuffedCount, _myFirstName, (int)(Time.Now / 5f) );
    }
}
