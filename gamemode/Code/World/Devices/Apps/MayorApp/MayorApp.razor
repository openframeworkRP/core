@using OpenFramework.Systems.Npc
@using OpenFramework.Systems.Jobs

@inherits BaseApp
@namespace OpenFramework.World.Devices.Apps.Mayor

<root>
    <button class="close">
        <svg src="ui/icons/close.svg" color="white" @onclick=@(() => OnClose()) />
    </button>

   <MayorApp_navigator/>

</root>

@code {
    public override string AppId => "maire";
    public override string DisplayName => "Maire";
    public override string Icon => "ui/icons/apps/gestions.svg";
    public override string IconColor => "#FE9900";
    public override string BackgroundColor => "#FFFFFF";
    public override bool IsSystemApp => (JobAccess == JobList.None ? false : true);
    public override JobList JobAccess => JobList.Mayor;
    public override Type SplashScreen => typeof(MayorApp_splash);
    public override DeviceKind Compatibility => DeviceKind.TV | DeviceKind.Phone | DeviceKind.Computer | DeviceKind.Tablet;
}
