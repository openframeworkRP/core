@using System;
@using Sandbox.UI;
@using Sandbox.UI.Navigation;

@namespace OpenFramework.World.Devices.Apps.Mayor
@inherits NavigationHost

<root>
    <div class="navbar">
        <svg class="branding" src="ui/icons/apps/gestions.svg" color="#FE9900" />
        <ul>
            <a href="/">
                <svg class="icon" src="ui/icons/home.svg" color="white" />
                <span>Accueil</span>
            </a>
            <a href="/finance">
                <svg class="icon" src="ui/icons/apps/finance.svg" color="white" />
                <span>Finance</span>
            </a>
            <a href="/regle">
                <svg class="icon" src="ui/icons/apps/reglement.svg" color="white" />
                <span>Reglement</span>
            </a>
            <a href="/employe">
                <svg class="icon" src="ui/icons/work.svg" color="white" />
                <span>Employe</span>
            </a>
        </ul>
    </div>
    <div class="navigator-canvas" slot="navigator-canvas" />
</root>

@code
{
    public MayorApp_navigator()
    {
        DefaultUrl = "/";
        AddDestination("/", typeof(HomePage));
        AddDestination("/finance", typeof(FinancePage));
    }
}
