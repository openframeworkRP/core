@using System;
@using Sandbox.UI;
@using Sandbox.UI.Navigation;

@namespace OpenFramework.World.Devices.Apps.Armury
@inherits NavigationHost

<root>
    <div class="navbar">
        <svg class="branding" src="ui/icons/apps/armurier_icon.svg" color="#FF5714" />
        <ul>
            <a href="/">
                <svg class="icon" src="ui/icons/home.svg" color="white" />
                <span>Accueil</span>
            </a>
            <a href="/finance">
                <svg class="icon" src="ui/icons/apps/finance.svg" color="white" />
                <span>Finance</span>
            </a>
            <a href="/stock">
                <svg class="icon" src="ui/icons/stock.svg" color="white" />
                <span>Stock</span>
            </a>
            <a href="/employe">
                <svg class="icon" src="ui/icons/work.svg" color="white" />
                <span>Employe</span>
            </a>
        </ul>
    </div>
    <div class="navigator-canvas" slot="navigator-canvas" />
</root>

@code
{
    public ArmuryApp_navigator()
    {
        DefaultUrl = "/stock";
        //AddDestination("/", typeof(HomePageArmury));
        //AddDestination("/finance", typeof(FinancePageArmury));
        AddDestination("/stock", typeof(StockPageArmury));
    }
}
