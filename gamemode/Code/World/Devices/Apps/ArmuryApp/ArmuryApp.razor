@using OpenFramework.Systems.Npc
@using OpenFramework.Systems.Jobs

@inherits BaseApp
@namespace OpenFramework.World.Devices.Apps.Armury

<root>
    <button class="close">
        <svg src="ui/icons/close.svg" color="white" @onclick=@(() => OnClose()) />
    </button>

   <ArmuryApp_navigator/>

</root>

@code {
    public override string AppId => "armury";
    public override string DisplayName => "Armurerie";
    public override string Icon => "ui/icons/apps/armurier_icon.svg";
    public override string IconColor => "#FF5714";
    public override string BackgroundColor => "#FFFFFF";
    public override bool IsSystemApp => (JobAccess == JobList.None ? false : true);
    public override JobList JobAccess => JobList.Armurier;
    public override Type SplashScreen => typeof(ArmuryApp_splash);
    public override DeviceKind Compatibility => DeviceKind.TV | DeviceKind.Phone | DeviceKind.Computer | DeviceKind.Tablet;
}
