@inherits Panel
@namespace Facepunch
@using System.Linq
@using static Facepunch.NotificationSystem

<div class="notif-header">
    <label>NOTIFICATIONS</label>
</div>

@code {
    public static NotificationContainer Instance { get; private set; }

    public const int MaxVisible = 6;

    public NotificationContainer()
    {
        Instance = this;
    }

    public override void Tick()
    {
        var items = Children.OfType<NotificationItem>().ToList();
        SetClass( "has-items", items.Any() );

        if ( NotificationSystem.PendingQueue.Count == 0 )
            return;

        if ( items.Count >= MaxVisible )
            return;

        var (type, message) = NotificationSystem.PendingQueue.First.Value;
        NotificationSystem.PendingQueue.RemoveFirst();
        AddChild( new NotificationItem( type, message ) );
    }
}
