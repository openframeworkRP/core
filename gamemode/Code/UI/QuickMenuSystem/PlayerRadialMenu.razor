        {
            var pawn = Client.Local?.PlayerPawn as PlayerPawn;
            if ( pawn != null && weapon.IsValid() )
                pawn.RequestPickupTarget( weapon.GameObject );
            Close();
        } ) );

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

    /// <summary>
    /// Ouvre un radial avec une option "Ouvrir le carton" sur un colis/container droppe
    /// (DroppedInventory). Le pickup vise force le passage par radial pour eviter qu'un
    /// hold E n'ouvre l'inventaire automatiquement (anciennement via fallback IUse).
    /// </summary>
    public static void OpenForDroppedInventory( DroppedInventory dropped )
    {
        if ( dropped == null || !dropped.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if ( needCreate )
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        Instance._debugMode = false;
        Instance._target = null;
        // Reutilise _furnitureTarget pour la verif de proximite dans Tick().
        Instance._furnitureTarget = dropped.GameObject;
        Instance._playerName = dropped.DisplayName;
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        var openLabel = $"Ouvrir le {dropped.DisplayName.ToLower()}";
        Instance.Items.Add( new RadialItem( openLabel, "ui/icons/backpack.svg", () =>
        {
            var pawn = Client.Local?.PlayerPawn as PlayerPawn;
            if ( pawn != null && dropped.IsValid() )
                pawn.RequestPickupTarget( dropped.GameObject );
            Close();
        } ) );

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

    /// <summary>
    /// Ouvre un radial avec une option "Ouvrir la poubelle" sur une TrashBin.
    /// Comme DroppedInventory, le hold E n'ouvre plus directement l'inventaire,
    /// tout passe par le radial pour eviter une ouverture parasite.
    /// </summary>
    public static void OpenForTrashBin( OpenFramework.Systems.Jobs.TrashBin trash )
    {
        if ( trash == null || !trash.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if ( needCreate )
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        Instance._debugMode = false;
        Instance._target = null;
        // Reutilise _furnitureTarget pour la verif de proximite dans Tick().
        Instance._furnitureTarget = trash.GameObject;
        Instance._playerName = trash.DisplayName ?? "Poubelle";
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        bool isBusyByOther = trash.IsBusy && trash.CurrentUser != Client.Local;
        var label = isBusyByOther ? "Occupée" : "Ouvrir la poubelle";

        Instance.Items.Add( new RadialItem( label, "ui/icons/backpack.svg", () =>
        {
            var pawn = Client.Local?.PlayerPawn as PlayerPawn;
            if ( pawn != null && trash.IsValid() )
                pawn.RequestPickupTarget( trash.GameObject );
            Close();
        }, Enabled: !isBusyByOther ) );

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

    /// <summary>
    /// Ouvre un radial avec "Récolter" et "Ramasser le pot" pour un WeedPot.
    /// Intercepté avant le handler WorldItem car WeedPot possède un composant WorldItem.
    /// </summary>
    public static void OpenForWeedPot( WeedPot pot )
    {
        if ( pot == null || !pot.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if ( needCreate )
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        bool canHarvest = pot.GrowStage >= pot.MaxStage;

        Instance._debugMode = false;
        Instance._target = null;
        Instance._furnitureTarget = pot.GameObject;
        Instance._playerName = pot.DisplayName ?? "Weed Pot";
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        Instance.Items.Add( new RadialItem(
            canHarvest ? "Récolter" : "Pas encore prête",
            "ui/icons/success.svg",
            () =>
            {
                if ( canHarvest )
                    Commands.RPC_HarvestWeedPot( pot.GameObject );
                Close();
            },
            Enabled: canHarvest
        ) );

        var wi = pot.Components.Get<WorldItem>( FindMode.EnabledInSelf );
        if ( wi != null )
        {
            Instance.Items.Add( new RadialItem( "Ramasser le pot", "ui/icons/backpack.svg", () =>
            {
                var pawn = Client.Local?.PlayerPawn as PlayerPawn;
                if ( pawn != null && pot.IsValid() )
                    pawn.RequestPickupItem( wi );
                Close();
            } ) );
        }

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

    /// <summary>
    /// Ouvre un radial avec uniquement "Grab" pour un objet decoratif marque "grab"
    /// (Rigidbody motion-enabled). Sert quand l'objet n'est ni furniture ni
    /// WorldItem : juste un prop physique qu'on veut pouvoir attraper.
    /// </summary>
    public static void OpenForGrabbable( GameObject target )
    {
        if ( target == null || !target.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if ( needCreate )
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        Instance._debugMode = false;
        Instance._target = null;
        // Reutilise _furnitureTarget pour la verif de proximite dans Tick().
        Instance._furnitureTarget = target;
        Instance._playerName = target.Name ?? "Objet";
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        Instance.Items.Add( new RadialItem( "Attraper", "ui/icons/transfer.svg", () =>
        {
            var pawn = Client.Local?.PlayerPawn as PlayerPawn;
            var grab = pawn?.Components.Get<GrabSystem>( FindMode.EverythingInSelfAndDescendants );
            if ( grab != null && target.IsValid() )
                grab.StartGrab( target );
            Close();
        } ) );

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

    public static void OpenForPoliceLocker( PoliceLocker locker )
    {
        if ( locker == null || !locker.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
