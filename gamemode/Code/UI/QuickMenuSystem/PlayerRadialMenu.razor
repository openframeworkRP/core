@namespace OpenFramework.UI.QuickMenuSystem
@attribute [StyleSheet]
@inherits Panel
@using Facepunch
@using OpenFramework
@using OpenFramework.Command
@using OpenFramework.Extension
@using OpenFramework.Inventory
@using OpenFramework.Systems.Jobs
@using OpenFramework.Systems.Pawn
@using OpenFramework.Systems.Tools
@using OpenFramework.UI.World.ShopSigns
@using OpenFramework.UI.World.Storage
@using OpenFramework.UI.World
@using OpenFramework.Systems.Crafting
@using OpenFramework.Inventory.UI
@using OpenFramework.Systems.Grab_System
@using OpenFramework.World
@using static Facepunch.NotificationSystem

<root class="@(IsOpen ? "open" : "")">
    @if (_subItems != null && UseListMode(_subItems))
    {
        <!-- Mode liste pour les sous-menus avec beaucoup d'items / texte long -->
        <div class="list-bg">
            <div class="list-title">@_subTitle</div>

            <div class="list-scroll">
                @foreach (var (item, index) in _subItems.Select((v, i) => (v, i)))
                {
                    var capturedItem = item;
                    <div class="list-item @(!item.Enabled ? "disabled" : "")"
                         onclick="@(() => OnSubItemClick(capturedItem))">
                        <img class="list-icon" src="@item.Icon" />
                        <span class="list-label">@item.Label</span>
                    </div>
                }
            </div>

            <div class="list-back" onclick="@(() => { _subItems = null; _subTitle = null; })">
                <span>Retour</span>
            </div>
        </div>
    }
    else
    {
        <div class="radial-bg">
            <div class="center-dot"></div>

            @if (_subItems != null)
            {
                <div class="radial-subtitle">@_subTitle</div>

                @foreach (var (item, index) in _subItems.Select((v, i) => (v, i)))
                {
                    float angle = GetAngle(index, _subItems.Count);
                    float distPct = 32f;
                    float xPct = 50f + MathF.Cos(angle) * distPct;
                    float yPct = 50f + MathF.Sin(angle) * distPct;

                    var capturedItem = item;
                    <div class="radial-item @(HoveredIndex == index ? "hovered" : "")"
                         style="left: @($"{xPct:F1}%"); top: @($"{yPct:F1}%");"
                         onclick="@(() => OnSubItemClick(capturedItem))">
                        <img class="radial-icon" src="@item.Icon" />
                        <span class="radial-label">@item.Label</span>
                    </div>
                }

                <div class="radial-back" onclick="@(() => { _subItems = null; _subTitle = null; })">
                    <span>Retour</span>
                </div>
            }
            else
            {
                @foreach (var (item, index) in Items.Select((v, i) => (v, i)))
                {
                    float angle = GetAngle(index, Items.Count);
                    float distPct = 32f;
                    float xPct = 50f + MathF.Cos(angle) * distPct;
                    float yPct = 50f + MathF.Sin(angle) * distPct;

                    <div class="radial-item @(HoveredIndex == index ? "hovered" : "") @(!item.Enabled ? "disabled" : "")"
                         style="left: @($"{xPct:F1}%"); top: @($"{yPct:F1}%");"
                         onclick="@(() => SelectItem(index))">
                        <img class="radial-icon" src="@item.Icon" />
                        <span class="radial-label">@item.Label</span>
                    </div>
                }
            }

            @if (HoveredIndex >= 0)
            {
                int count = _subItems?.Count ?? Items.Count;
                if (HoveredIndex < count)
                {
                    float hAngle = GetAngle(HoveredIndex, count);
                    <div class="selection-line" style="transform: rotate(@($"{hAngle * 180f / MathF.PI + 90f:F1}deg"))"></div>
                }
            }

            <div class="radial-player-name">@_playerName</div>
        </div>
    }
</root>

@code {
    public static PlayerRadialMenu Instance { get; private set; }

    public bool IsOpen { get; private set; }
    public int HoveredIndex { get; private set; } = -1;

    private List<RadialItem> Items { get; set; } = new();
    private PlayerPawn _target;
    private string _playerName;

    // Sub-menu state
    private List<RadialItem> _subItems;
    private string _subTitle;
    private bool _debugMode;
    private GameObject _furnitureTarget;

    public record RadialItem(string Label, string Icon, Action OnSelect, List<RadialItem> Children = null, bool Enabled = true);

    /// <summary>
    /// Seuil au-delà duquel un sous-menu bascule en mode liste (trop d'items ou labels trop longs).
    /// </summary>
    private const int ListModeThreshold = 6;
    private const int ListModeLabelLength = 25;

    private static bool UseListMode(List<RadialItem> items)
    {
        if (items == null) return false;
        if (items.Count >= ListModeThreshold) return true;
        if (items.Any(i => i.Label.Length > ListModeLabelLength)) return true;
        return false;
    }

    protected override void OnAfterTreeRender(bool firstTime)
    {
        if (firstTime)
            Instance = this;
    }

    private static RealTimeSince _lastOpenTime;

    public static void Open(PlayerPawn target)
    {
        Log.Info( $"[Radial.Open] called target={target?.DisplayName ?? "<null>"} target.IsValid={target.IsValid()} target.IsProxy={target?.IsProxy} _lastOpenTime={(float)_lastOpenTime:F2}s" );
        if (_lastOpenTime < 0.5f) { Log.Info( "[Radial.Open] abort : cooldown < 0.5s" ); return; }
        _lastOpenTime = 0f;

        if (Instance != null && Instance.IsOpen)
        {
            Log.Info( "[Radial.Open] menu deja ouvert → on ferme (toggle)" );
            Instance.IsOpen = false;
            return;
        }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if (needCreate)
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>(true);
            if (hud == null) { Log.Warning( "[Radial.Open] abort : MainHUD introuvable" ); return; }

            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild(Instance);
        }

        if (Instance == null) { Log.Warning( "[Radial.Open] abort : Instance null apres create" ); return; }

        Instance._debugMode = false;
        Instance._target = target;
        Instance._playerName = target.DisplayName;
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        BuildItems(target, Instance.Items);

        Log.Info( $"[Radial.Open] {Instance.Items.Count} items construits pour {target.DisplayName}" );
        if (Instance.Items.Count == 0) { Log.Warning( "[Radial.Open] abort : aucun item construit" ); return; }

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
        Log.Info( $"[Radial.Open] menu ouvert pour {target.DisplayName}" );
    }

    /// <summary>
    /// Ouvre un radial avec une option "Ramasser" sur un item au sol.
    /// Le pickup passe par RequestPickupHost cote PlayerPawn (verifie deja IsValid
    /// host-side, donc atomique : pas de duplication possible meme sur double-click).
    /// </summary>
    public static void OpenForWorldItem( WorldItem worldItem )
    {
        if ( worldItem == null || !worldItem.IsValid() ) return;
        if ( _lastOpenTime < 0.5f ) return;
        _lastOpenTime = 0f;

        if ( Instance != null && Instance.IsOpen ) { Instance.IsOpen = false; return; }

        bool needCreate = false;
        try { needCreate = Instance == null || Instance.Parent == null; }
        catch { needCreate = true; }

        if ( needCreate )
        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        var meta = worldItem.Item?.Metadata;
        var qty = worldItem.Item?.Quantity ?? 0;
        var label = meta != null
            ? (qty > 1 ? $"Ramasser {qty}x {meta.Name}" : $"Ramasser {meta.Name}")
            : "Ramasser";

        Instance._debugMode = false;
        Instance._target = null;
        // Reutilise _furnitureTarget pour la verif de proximite dans Tick().
        // Sans ca, Tick() referme le menu immediatement (target+furniture null).
        Instance._furnitureTarget = worldItem.GameObject;
        Instance._playerName = meta?.Name ?? "Item";
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

        Instance.Items.Add( new RadialItem( label, "ui/icons/backpack.svg", () =>
        {
            var pawn = Client.Local?.PlayerPawn as PlayerPawn;
            if ( pawn != null && worldItem.IsValid() )
                pawn.RequestPickupItem( worldItem );
            Close();
        } ) );

        Instance.IsOpen = true;
        Instance.HoveredIndex = -1;
    }

