        {
            Instance = null;
            var hud = Game.ActiveScene?.GetComponentInChildren<Facepunch.UI.MainHUD>( true );
            if ( hud == null ) return;
            Instance = new PlayerRadialMenu();
            Instance.Items = new();
            hud.Panel.AddChild( Instance );
        }

        if ( Instance == null ) return;

        Instance._debugMode = false;
        Instance._target = null;
        // Reutilise _furnitureTarget pour la verif de proximite dans Tick().
        Instance._furnitureTarget = weapon.GameObject;
        Instance._playerName = weapon.GameObject?.Name ?? "Arme";
        Instance._subItems = null;
        Instance._subTitle = null;
        Instance.Items ??= new();
        Instance.Items.Clear();

