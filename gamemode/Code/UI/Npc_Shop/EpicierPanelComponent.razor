@using Sandbox;
@using Sandbox.UI;
@using OpenFramework.Command
@using OpenFramework.GameLoop
@using OpenFramework.Inventory
@using OpenFramework.Systems
@using OpenFramework.Systems.Jobs
@using OpenFramework.Systems.Shop_System
@using static Facepunch.NotificationSystem
@inherits PanelComponent
@namespace OpenFramework

<root>
<div class="wrapper">

    @* ── HEADER ──*@
    <div class="header">
        <div class="header-top">
            <button class="close-btn" @onclick="@(() => Enabled = false)">✕</button>
            <span class="shop-name">@EpicierCatalogue.DisplayName</span>
            <div class="wallet">
                <span class="wallet-label">Solde</span>
                <span class="wallet-amount">$@MoneySystem.Get()</span>
            </div>
        </div>
        <div class="categories">
            <div class="category @(SelectedCategory == null ? "active" : "")"
                 @onclick="@(() => SelectedCategory = null)">
                Tous
            </div>
            @foreach (var cat in EpicierCatalogue.Categories)
            {
                var localCat = cat;
                <div class="category @(SelectedCategory == localCat ? "active" : "")"
                     @onclick="@(() => SelectedCategory = localCat)">
                    @localCat.Name
                </div>
            }
        </div>
    </div>

    <div class="body">

        @* ── GRILLE ITEMS ──*@
        <div class="grid">
            @foreach (var item in SelectedItems)
            {
                var localItem = item;
                <div class="card">
                    <div class="card-preview">
                        @if (localItem.Item?.WorldObjectPrefab != null)
                        {
                            <OpenFramework.Model3DIcon ModelPath="@localItem.Item.WorldObjectPrefab.ResourcePath" />
                        }
                    </div>
                    <div class="card-bottom">
                        <span class="card-name">@localItem.Item?.Name</span>
                        <div class="card-footer">
                            <span class="card-price">$@localItem.Item.Price</span>
                            @if (localItem.Item != null)
                            {
                                var localMeta = localItem.Item;
                                <button class="card-btn" @onclick="@(() => AddToCart(localMeta, localItem.Item.Price))">
                                    +
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── PANIER ──*@
        <div class="cart">
            <span class="cart-title">Panier</span>

            <div class="cart-lines">
                @if (CartLines.Count == 0)
                {
                    <div class="cart-empty">Votre panier est vide</div>
                }
                else
                {
                    @foreach (var line in CartLines)
                    {
                        var localLine = line;
                        <div class="cart-line">
                            <div class="cart-line-left">
                                <span class="cart-line-name">@localLine.Item.Name</span>
                                <span class="cart-line-price">$@(localLine.Price * localLine.Quantity)</span>
                            </div>
                            <div class="cart-qty">
                                <button @onclick="@(() => Decrement(localLine))">−</button>
                                <span>@localLine.Quantity</span>
                                <button @onclick="@(() => Increment(localLine))">+</button>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="cart-footer">
                <div class="cart-total">
                    <span>Total</span>
                    <span class="cart-total-price">$@CartTotal</span>
                </div>
                <div class="cart-buy">
                    <button class="btn-clear" @onclick="@ClearCart">Vider</button>
                    <button class="btn-buy" @onclick="@Purchase">Acheter</button>
                </div>
            </div>
        </div>

    </div>


</div>
</root>

@code
{
    [Property] public ShopCatalogueResource EpicierCatalogue { get; set; }
    [Property] public float MaxDistance { get; set; } = 100f;

    /// <summary>
    /// Si défini (≠ None), seuls les joueurs ayant ce métier peuvent ouvrir le shop.
    /// Les autres reçoivent une notification d'erreur.
    /// </summary>
    [Property] public JobList RequiredJob { get; set; } = JobList.None;

    Client player => Client.Local;
    InventoryContainer Container => Client.Local?.PlayerPawn?.GameObject.Components.Get<InventoryContainer>(FindMode.EnabledInSelfAndChildren);
    ShopCatalogueResource.ShopCategory SelectedCategory { get; set; }

    IEnumerable<ShopCatalogueResource.ShopItem> SelectedItems =>
        SelectedCategory == null
            ? EpicierCatalogue.Categories.SelectMany(c => c.Items.Where(i => i.Item != null))
            : SelectedCategory.Items.Where(i => i.Item != null);

    private NpcLogical OwningNpc => GameObject?.Root?.Components.Get<NpcLogical>(FindMode.EnabledInSelfAndDescendants);

    protected override void OnEnabled()
    {
        base.OnEnabled();

        // Filtre par métier — bloque l'ouverture si le joueur n'a pas le bon job.
        if ( RequiredJob != JobList.None )
        {
            var localJob = Client.Local?.Data?.Job;
            bool jobOk = !string.IsNullOrEmpty( localJob ) &&
                         localJob.Equals( RequiredJob.ToString(), StringComparison.OrdinalIgnoreCase );
            if ( !jobOk )
            {
                Client.Local?.Notify( NotificationType.Error, $"🔒 Réservé aux {RequiredJob}." );
                Enabled = false;
                return;
            }
        }

        OwningNpc?.ClientDebug($"EpicierPanelComponent.OnEnabled Catalogue={(EpicierCatalogue != null ? EpicierCatalogue.DisplayName : "NULL")} MaxDistance={MaxDistance} GameObject={GameObject?.Name}");
    }

    protected override void OnDisabled()
    {
        base.OnDisabled();
        OwningNpc?.ClientDebug($"EpicierPanelComponent.OnDisabled");
    }

    protected override void OnUpdate()
    {
        if (!Enabled) return;

        var pawn = Client.Local?.PlayerPawn;
        if (pawn == null || !pawn.IsValid()) return;

        var distance = Vector3.DistanceBetween(pawn.WorldPosition, GameObject.WorldPosition);
        if (distance > MaxDistance)
        {
            OwningNpc?.ClientDebug($"EpicierPanelComponent distance={distance:F1} > MaxDistance={MaxDistance} -> fermeture");
            ClearCart();
            Enabled = false;
        }
    }

    // === Panier ===
    record CartLine(ItemMetadata Item, int Price)
    {
        public int Quantity { get; set; } = 1;
    }

    List<CartLine> CartLines { get; set; } = new();
    int CartTotal => CartLines.Sum(l => l.Price * l.Quantity);

    void AddToCart(ItemMetadata item, int price)
    {
        var existing = CartLines.FirstOrDefault(l => l.Item == item);
        if (existing != null) existing.Quantity++;
        else CartLines.Add(new CartLine(item, price));
    }

    void Increment(CartLine line) => line.Quantity++;

    void Decrement(CartLine line)
    {
        if (line.Quantity <= 1) CartLines.Remove(line);
        else line.Quantity--;
    }

    void ClearCart() => CartLines.Clear();

    void Purchase()
    {
        if (player == null) return;
        if (CartLines.Count == 0) return;

        if (MoneySystem.Get() < CartTotal)
        {
            player.Notify(NotificationType.Error, "Vous n'avez pas assez d'argent.");
            return;
        }

        foreach (var line in CartLines)
        {
            MoneySystem.Remove(line.Price * line.Quantity);
            // Un seul appel avec la quantite totale : si l'inventaire deborde,
            // tout le surplus va dans UN SEUL carton (au lieu d'un carton par item).
            InventoryContainer.Add(Container, line.Item.ResourceName, line.Quantity);

            player.Notify(NotificationType.Success, $"Achat de {line.Item.Name} x{line.Quantity} pour ${line.Price * line.Quantity}.");
        }

        ClearCart();
    }

    protected override int BuildHash() =>
        HashCode.Combine(SelectedCategory, CartLines.Count, CartTotal, MoneySystem.Get());
}
