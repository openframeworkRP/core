@namespace OpenFramework.UI
@attribute [StyleSheet]
@inherits Panel

@if (Client.Local?.PlayerPawn?.HealthComponent?.State != LifeState.Alive)
    return;

<root>
    <div @ref="_hungerOverlay"      class="overlay hunger_overlay" />
    <div @ref="_thirstOverlay"      class="overlay thirst_overlay" />
    <div @ref="_exhaustDarkOverlay" class="overlay exhaust_dark_overlay" />
    <div @ref="_exhaustFlashOverlay" class="overlay exhaust_flash_overlay" />
    <div @ref="_sprintOverlay"      class="overlay sprint_overlay" />
</root>

@code {
    Panel _hungerOverlay;
    Panel _thirstOverlay;
    Panel _exhaustFlashOverlay;
    Panel _exhaustDarkOverlay;
    Panel _sprintOverlay;

    float _lastHunger   = -1f;
    float _lastThirst   = -1f;
    bool  _lastExhausted = false;
    float _exhaustFlash  = 0f;
    float _exhaustDark   = 0f;
    float _sprintBlur    = 0f;
    SoundHandle _breathHandle;

    Client Self => Client.Local;

    float HungerOpacity()
    {
        var hunger = Self?.Data?.Hunger ?? 100f;
        if (hunger >= 50f) return 0f;
        var t = 1f - (hunger / 50f);
        var pulse = (MathF.Cos(Time.Now * 1.5f) / 2f + 0.5f) * t * 0.12f;
        return t * 0.30f + pulse;
    }

    float ThirstOpacity()
    {
        var thirst = Self?.Data?.Thirst ?? 100f;
        if (thirst >= 50f) return 0f;
        var t = 1f - (thirst / 50f);
        var pulse = (MathF.Cos(Time.Now * 1.5f + 1.2f) / 2f + 0.5f) * t * 0.12f;
        return t * 0.30f + pulse;
    }

    public override void Tick()
    {
        if (Self == null) return;

        var hunger    = Self?.Data?.Hunger ?? 100f;
        var thirst    = Self?.Data?.Thirst ?? 100f;
        var stamina   = Self?.Data?.Stamina ?? 100f;
        var exhausted = Self?.PlayerPawn?.IsExhausted ?? false;
        bool sprinting = Input.Down("Run") && !exhausted;

        // Sons par seuil faim/soif
        if (_lastHunger >= 0f)
        {
            TryPlayThresholdSound( _lastHunger, hunger, 50f, "sounds/ui/hunger_warn.sound" );
            TryPlayThresholdSound( _lastHunger, hunger, 25f, "sounds/ui/hunger_critical.sound" );
        }
        if (_lastThirst >= 0f)
        {
            TryPlayThresholdSound( _lastThirst, thirst, 50f, "sounds/ui/thirst_warn.sound" );
            TryPlayThresholdSound( _lastThirst, thirst, 25f, "sounds/ui/thirst_critical.sound" );
        }

        // Déclenchement épuisement
        if (exhausted && !_lastExhausted)
        {
            _exhaustFlash = 1f;
            TryPlayThresholdSound( 100f, 0f, 50f, "sounds/ui/exhaustion.sound" );
        }

        _lastHunger   = hunger;
        _lastThirst   = thirst;
        _lastExhausted = exhausted;

        // Flash blanc : disparaît en ~0.4s
        _exhaustFlash = MathF.Max(0f, _exhaustFlash - Time.Delta * 2.5f);

        // Vignette noire soutenue pendant IsExhausted, avec léger pulse
        if (exhausted)
        {
            float target = 0.55f + MathF.Cos(Time.Now * 1.8f) * 0.07f;
            float speed  = target > _exhaustDark ? 6f : 1.5f;
            _exhaustDark = _exhaustDark + (target - _exhaustDark) * MathF.Min(1f, Time.Delta * speed);
        }
        else
        {
            _exhaustDark = MathF.Max(0f, _exhaustDark - Time.Delta * 4f);
        }

        // Flou latéral sprint (rampe 80%→0% stamina)
        float sprintTarget = sprinting ? MathF.Max(0f, 1f - stamina / 80f) * 0.75f : 0f;
        float lerpSpeed    = sprintTarget > _sprintBlur ? 5f : 3f;
        _sprintBlur = _sprintBlur + (sprintTarget - _sprintBlur) * MathF.Min(1f, Time.Delta * lerpSpeed);

        // Son de respiration : démarre à 70% stamina, volume croissant
        UpdateBreathSound(stamina, sprinting);

        // Application
        if (_hungerOverlay.IsValid())       _hungerOverlay.Style.Opacity      = HungerOpacity();
        if (_thirstOverlay.IsValid())       _thirstOverlay.Style.Opacity      = ThirstOpacity();
        if (_exhaustFlashOverlay.IsValid()) _exhaustFlashOverlay.Style.Opacity = _exhaustFlash;
        if (_exhaustDarkOverlay.IsValid())  _exhaustDarkOverlay.Style.Opacity  = _exhaustDark;
        if (_sprintOverlay.IsValid())       _sprintOverlay.Style.Opacity       = _sprintBlur;
    }

    void UpdateBreathSound( float stamina, bool sprinting )
    {
        bool shouldBreathe = sprinting && stamina < 70f;
        float vol = shouldBreathe ? (1f - stamina / 70f) : 0f;

        if (shouldBreathe)
        {
            if (!_breathHandle.IsValid)
            {
                var snd = ResourceLibrary.Get<SoundEvent>("sounds/runbreath.sound");
                if (snd != null) _breathHandle = Sound.Play(snd);
            }
            if (_breathHandle.IsValid) _breathHandle.Volume = vol;
        }
        else
        {
            if (_breathHandle.IsValid)
            {
                _breathHandle.Stop();
                _breathHandle = default;
            }
        }
    }

    static void TryPlayThresholdSound( float last, float current, float threshold, string path )
    {
        if (last > threshold && current <= threshold)
        {
            var sound = ResourceLibrary.Get<SoundEvent>( path );
            if (sound != null) Sound.Play( sound );
        }
    }
}
