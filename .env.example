# ============================================================
# OpenFramework Core — variables d'environnement
# ============================================================
# Copie ce fichier vers `.env` puis renseigne les valeurs avant
# `docker compose up`.
# `.env` est dans .gitignore — ne jamais commiter.
# ============================================================

# ── Base de données PostgreSQL ────────────────────────────────
POSTGRES_DB=OpenFrameworkDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMeStrongP@ssw0rd!

# Port exposé pour PostgreSQL
POSTGRES_PORT=5432

# ── Backend .NET API (gamemode auth, characters, inventaire) ──
# Port exposé pour l'API .NET (le gamemode tape dessus)
API_PORT=8443

# Port exposé pour Adminer (UI web pour la DB)
ADMINER_PORT=8080

# Port exposé pour Redis (cache distribué)
REDIS_PORT=6379

# Secret partagé entre l'API et le gamemode (auth serveur)
# Génère une chaîne aléatoire longue : `openssl rand -hex 32`
SERVER_SECRET=

# Clé de signature des JWT (chaîne aléatoire longue, 64+ caractères)
# Génère : `openssl rand -base64 64`
JWT_KEY=

# ── Website (devblog + admin panel) ───────────────────────────
# Clé API Steam — obtenir sur https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Secret de session Express (chaîne aléatoire longue)
# Génère : `openssl rand -hex 32`
SESSION_SECRET=

# SteamIDs autorisés à accéder à l'admin (séparés par virgule)
# Trouve ton SteamID64 sur https://steamid.io/
ALLOWED_STEAM_IDS=

# URLs publiques (sans slash final)
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:4173

# Secret partagé avec l'API .NET du jeu (même valeur que SERVER_SECRET)
GAME_SERVER_SECRET=

# URL de l'API du jeu pour le pont devblog -> jeu
GAME_API_URL=http://core-api:8443

# ── Optionnels ───────────────────────────────────────────────
NODE_ENV=production
OPENAI_API_KEY=
VITE_MAINTENANCE=false

# Intégration NextCloud pour les assets (laisse vide si non utilisé)
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_TOKEN=
NEXTCLOUD_ROOT=/unreal_asset
NEXTCLOUD_ASSET_ROOT=/unreal_asset

FAB_SCRAPER_URL=http://localhost:8000
