# ============================================================
# OpenFramework Core — variables d'environnement
# ============================================================
# Copie ce fichier vers `.env` puis renseigne les valeurs avant
# `docker compose up`.
# `.env` est dans .gitignore — ne jamais commiter.
# ============================================================

# ── Backend .NET API (gamemode auth, characters, inventaire) ──
# Mot de passe SA pour le serveur SQL Server local (>= 8 caracteres,
# au moins une majuscule, un chiffre, un caractere special)
MSSQL_SA_PASSWORD=ChangeMeStrongP@ssw0rd!

# Nom de la base de donnees du jeu
DB_NAME=OpenFrameworkDb

# Port expose pour l'API .NET (le gamemode tape dessus)
API_PORT=8443

# Port expose pour Adminer (UI web pour la DB)
ADMINER_PORT=8080

# Secret partage entre l'API et le gamemode (auth serveur)
# Genere une chaine aleatoire longue : `openssl rand -hex 32`
SERVER_SECRET=

# Cle de signature des JWT (chaine aleatoire longue, 64+ caracteres)
# Genere : `openssl rand -base64 64`
JWT_KEY=

# ── Website (devblog + admin panel) ───────────────────────────
# Cle API Steam — obtenir sur https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Secret de session Express (chaine aleatoire longue)
# Genere : `openssl rand -hex 32`
SESSION_SECRET=

# SteamIDs autorises a acceder a l'admin (separes par virgule)
# Trouve ton SteamID64 sur https://steamid.io/
ALLOWED_STEAM_IDS=

# URLs publiques (sans slash final)
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:4173

# Secret partage avec l'API .NET du jeu (meme valeur que SERVER_SECRET)
GAME_SERVER_SECRET=

# URL de l'API du jeu pour le pont devblog -> jeu
GAME_API_URL=http://localhost:8443

# ── Optionnels ───────────────────────────────────────────────
NODE_ENV=production
OPENAI_API_KEY=
VITE_MAINTENANCE=false

# Integration NextCloud pour les assets (laisse vide si non utilise)
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_TOKEN=
NEXTCLOUD_ROOT=/unreal_asset
NEXTCLOUD_ASSET_ROOT=/unreal_asset

FAB_SCRAPER_URL=http://localhost:8000
