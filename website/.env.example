# === Backend API ===
# URL publique du backend (sans slash final)
BACKEND_URL=http://localhost:3001

# URL publique du frontend (sans slash final)
FRONTEND_URL=http://localhost:4173

# Clé API Steam — obtenir sur https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Secret de session Express (chaîne aléatoire longue)
SESSION_SECRET=un-secret-tres-long-et-aleatoire

# SteamIDs autorisés à accéder à l'admin (séparés par virgule)
# Trouve ton SteamID64 sur https://steamid.io/
ALLOWED_STEAM_IDS=

# Optionnel
OPENAI_API_KEY=
NODE_ENV=production

# Mode maintenance : mettre à true pour activer la page maintenance sur le site public
# (seul /admin reste accessible)
VITE_MAINTENANCE=false # true ou false

NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_TOKEN=
NEXTCLOUD_ROOT=/unreal_asset